{
  "name": "infinity-chat",
  "version": "1.0.0",
  "description": "Infinity-Chat: A cross-platform desktop AI chat interface with support for OpenAI, Google Gemini, and OpenRouter",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [
    "AI",
    "Chat",
    "Electron",
    "OpenAI",
    "Gemini"
  ],
  "author": "Infinity Chat Team",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.2.1",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.infinitychat.desktop",
    "productName": "Infinity Chat",
    "files": [
      "main.js",
      "preload.js",
      "index.html"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}

